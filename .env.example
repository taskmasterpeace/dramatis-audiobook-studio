# Copy to .env and fill in only the engines you want to use.
# DRAMATIS runs fully offline with none of these set — Kokoro narration,
# Qwen3 character voices, CLAP sound effects and alignment are all local.
#
# Precedence: real environment > .env.local > .env > files listed in
# DRAMATIS_ENV_FILES (a ; or , separated path list, if you already keep keys
# somewhere else).

# Premium voices. ElevenLabs = your own voice roster + Music.
ELEVENLABS_API_KEY=

# Gemini 3.1 Flash TTS runs through Replicate — the strongest directed/character
# voices, and the cheapest premium option per line.
REPLICATE_API_TOKEN=

# Cinematic set-pieces via Seed Audio on fal.
FAL_KEY=

# Scene analysis fallback when you don't want to run a local model.
OPENROUTER_API_KEY=
